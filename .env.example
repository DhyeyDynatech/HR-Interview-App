# =============================================================
#  HR Interviewer — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# =============================================================


# -------------------------------------------------------------
#  App
# -------------------------------------------------------------
NEXT_PUBLIC_LIVE_URL=localhost:3000          # Base URL (no https://) — set to your domain in production


# -------------------------------------------------------------
#  Supabase  (https://supabase.com/dashboard/project/<id>/settings/api)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # Server-only — never expose to browser


# -------------------------------------------------------------
#  Retell AI  (https://app.retellai.com/apikey)
# -------------------------------------------------------------
RETELL_API_KEY=<your-retell-api-key>


# -------------------------------------------------------------
#  OpenAI  (https://platform.openai.com/api-keys)
# -------------------------------------------------------------
OPENAI_API_KEY=<your-openai-api-key>


# -------------------------------------------------------------
#  Azure OpenAI  (https://portal.azure.com → Azure OpenAI → Keys)
# -------------------------------------------------------------
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_GPT5_MINI=<your-deployment-name>   # Deployment name from Azure AI Foundry


# -------------------------------------------------------------
#  Email — Power Automate Flow
#  (Power Automate → Your flow → ... → Copy HTTP URL)
# -------------------------------------------------------------
POWER_AUTOMATE_FLOW_URL=<your-power-automate-http-trigger-url>
FIXED_RECRUITER_EMAIL=<recruiter-email@yourdomain.com>      # Email that receives interview notifications


# -------------------------------------------------------------
#  Vercel Blob  (https://vercel.com/dashboard/stores)
# -------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=<your-vercel-blob-token>


# -------------------------------------------------------------
#  Auth Security
#  IMPORTANT: Use strong random values in production.
#  Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------------------------
PASSWORD_SALT=<random-32-char-string>   # Used to hash passwords — change from default!
JWT_SECRET=<random-64-char-string>      # Used to sign JWT tokens — change from default!
